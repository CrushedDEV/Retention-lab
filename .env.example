# ---- Base de datos (PostgreSQL) ----
# Local con Docker o un proveedor como Neon / Supabase / Railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/script_intelligence?schema=public"

# ---- NextAuth ----
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (Google Cloud Console) ----
# Habilita "YouTube Data API v3" y crea credenciales OAuth 2.0.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Administración ----
# Emails con acceso al panel de administración (separados por comas).
ADMIN_EMAILS="tu@email.com"

# ---- OpenAI ----
OPENAI_API_KEY=""
# Modelo a usar para análisis y generación
OPENAI_MODEL="gpt-4o"

# ---- Extracción de captions en producción (OPCIONAL) ----
# YouTube bloquea el scraping de subtítulos desde IPs de datacenter (Vercel).
# Si defines una API key de Supadata (https://supadata.ai), la app la usará
# como respaldo cuando el método gratuito falle. Si la dejas vacía, el usuario
# siempre puede pegar la transcripción manualmente.
SUPADATA_API_KEY=""
